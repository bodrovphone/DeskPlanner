---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketingNav from '../../components/MarketingNav.astro';
import MarketingFooter from '../../components/MarketingFooter.astro';
import { getCollection } from 'astro:content';
import '../../styles/marketing.css';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'OhMyDesk Blog',
  description: 'Practical guides for independent coworking operators.',
  url: 'https://ohmydesk.app/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'OhMyDesk',
    url: 'https://ohmydesk.app',
    logo: 'https://ohmydesk.app/favicon.svg',
  },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    url: `https://ohmydesk.app/blog/${post.id}/`,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
    author: { '@type': 'Person', name: post.data.author },
  })),
};
---

<BaseLayout
  title="OhMyDesk Blog — Practical Guides for Running a Coworking Space"
  description="Practical guides for independent coworking operators: how to manage dedicated desks, handle member freezes, collect payments, and stop running your space on a spreadsheet."
  canonical="https://ohmydesk.app/blog/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <MarketingNav />
  <main>
    <section class="hero">
      <span class="eyebrow">Blog</span>
      <h1>Run your coworking space <span class="accent">like it's 2026.</span></h1>
      <p class="lede">
        Practical guides for independent coworking operators — how to manage
        dedicated desks, handle member holidays, collect payments, and retire
        the spreadsheet without losing a single booking.
      </p>
    </section>

    {posts.length === 0 ? (
      <section class="empty">
        <p>No posts yet — check back soon.</p>
      </section>
    ) : (
      <section class="posts">
        <ol class="post-list">
          {posts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.id}/`}>
                <time datetime={post.data.publishDate.toISOString()} class="post-date">
                  {dateFmt.format(post.data.publishDate)}
                </time>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-excerpt">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="tags">
                    {post.data.tags.map((t) => <span class="tag">{t}</span>)}
                  </div>
                )}
                <span class="read-more">Read post →</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <section class="cta-section">
      <h2>Try OhMyDesk free for 3 months.</h2>
      <p>No credit card. No contract. Under 2 minutes to set up.</p>
      <a href="/signup/" class="cta-btn">Start Free Trial</a>
    </section>

    <MarketingFooter />
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero {
    padding: 96px 0 48px;
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 24px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 24px;
    letter-spacing: -1px;
  }
  .hero h1 .accent { color: var(--green); }
  .hero .lede {
    max-width: 620px;
    margin: 0 auto;
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .empty {
    padding: 48px 0 96px;
    text-align: center;
    color: var(--text-secondary);
  }

  .posts {
    padding: 32px 0 72px;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-card a {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 32px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .post-card a:hover {
    border-color: rgba(52, 211, 153, 0.35);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(52, 211, 153, 0.1);
    transform: translateY(-2px);
  }
  .post-date {
    font-family: 'SF Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
  }
  .post-title {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    color: var(--text-primary);
    margin: 4px 0 0;
    letter-spacing: -0.3px;
    line-height: 1.25;
  }
  .post-excerpt {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 4px 0 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  .tag {
    font-family: 'SF Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--green);
    background: var(--green-faint);
    padding: 3px 10px;
    border-radius: 999px;
  }
  .read-more {
    font-size: 13px;
    color: var(--green);
    font-weight: 600;
    margin-top: 8px;
  }

  .cta-section {
    text-align: center;
    padding: 72px 0 80px;
    border-top: 1px solid var(--border);
  }
  .cta-section h2 {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }
  .cta-section p {
    color: var(--text-secondary);
    font-size: 17px;
    margin: 0 0 32px;
  }
  .cta-btn {
    display: inline-block;
    padding: 16px 36px;
    background: var(--green);
    color: var(--bg);
    border-radius: 10px;
    font-family: 'SF Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta-btn:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--green-glow);
  }
</style>
