---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketingNav from '../components/MarketingNav.astro';
import MarketingFooter from '../components/MarketingFooter.astro';
import '../styles/marketing.css';
import { changelog, type ChangelogEntry } from '../data/changelog.ts';

// Group entries by "YYYY-MM" while preserving newest-first order of the source array.
const groups: { key: string; label: string; entries: ChangelogEntry[] }[] = [];
const monthFmt = new Intl.DateTimeFormat('en', { month: 'long', year: 'numeric' });

for (const entry of changelog) {
  const key = entry.date.slice(0, 7); // "2026-04"
  let group = groups.find(g => g.key === key);
  if (!group) {
    const [y, m] = key.split('-').map(Number);
    // Use UTC to avoid TZ-dependent month drift
    const label = monthFmt.format(new Date(Date.UTC(y, m - 1, 1)));
    group = { key, label, entries: [] };
    groups.push(group);
  }
  group.entries.push(entry);
}

const dayFmt = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric' });
function formatDay(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return dayFmt.format(new Date(Date.UTC(y, m - 1, d)));
}
---

<BaseLayout
  title="OhMyDesk Changelog — Product Updates"
  description="New features and improvements to the OhMyDesk coworking desk booking platform — Stripe payments, flex plans, floor plans, meeting rooms and more. Shipped weekly, newest first."
  canonical="https://ohmydesk.app/changelog/"
>
  <MarketingNav />
  <main>
    <section class="hero">
      <span class="eyebrow-chip">Changelog</span>
      <h1>What's new in OhMyDesk</h1>
      <p class="intro">
        New features and improvements shipped weekly — everything we've added to help you run a smoother coworking space. Newest first.
      </p>
    </section>

    <section class="timeline">
      {groups.map(group => (
        <div class="month-block">
          <h2 class="month-heading">{group.label}</h2>
          <ol class="entries">
            {group.entries.map(entry => (
              <li class="entry">
                <time datetime={entry.date} class="entry-date">{formatDay(entry.date)}</time>
                <div class="entry-body">
                  <h3 class="entry-title">{entry.title}</h3>
                  {entry.tags && entry.tags.length > 0 && (
                    <div class="tags">
                      {entry.tags.map(t => <span class="tag">{t}</span>)}
                    </div>
                  )}
                  <p class="entry-desc">{entry.description}</p>
                  {entry.linkedFeature && (
                    <a href={`/features/${entry.linkedFeature}/`} class="learn-more">
                      Read the full feature →
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </section>

    <section class="cta-section">
      <h2>Try every feature free for 3 months.</h2>
      <p>No credit card. Set up your space in under two minutes.</p>
      <a href="/signup/" class="cta-btn">Start Free Trial</a>
    </section>

    <MarketingFooter />
  </main>
</BaseLayout>

<style is:global>
  main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .hero {
    padding: 56px 0 48px;
    max-width: 760px;
  }
  .eyebrow-chip {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px;
    letter-spacing: -0.75px;
  }
  .hero .intro {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Timeline */
  .timeline {
    padding: 16px 0 72px;
  }
  .month-block + .month-block {
    margin-top: 56px;
  }
  .month-heading {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 28px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Entry — two-column layout: sticky date chip + body */
  .entry {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: 24px;
    align-items: start;
  }
  .entry-date {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 12px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-muted);
    padding-top: 4px;
    white-space: nowrap;
  }
  .entry-body {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px 24px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .entry-body:hover {
    border-color: rgba(52, 211, 153, 0.3);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(52, 211, 153, 0.08);
  }
  .entry-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 10px;
    line-height: 1.3;
    letter-spacing: -0.2px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }
  .tag {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 4px;
  }
  .entry-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 14px;
  }
  .entry-body > .entry-desc:last-child {
    margin-bottom: 0;
  }
  .learn-more {
    font-size: 13px;
    color: var(--green);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .learn-more:hover {
    color: var(--green-dim, var(--green));
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .entry-date {
      padding-top: 0;
    }
  }

  /* CTA (copied from features/[slug].astro for consistency) */
  .cta-section {
    text-align: center;
    padding: 72px 0 80px;
    border-top: 1px solid var(--border);
  }
  .cta-section h2 {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }
  .cta-section p {
    color: var(--text-secondary);
    font-size: 17px;
    margin: 0 0 32px;
  }
  .cta-btn {
    display: inline-block;
    padding: 16px 36px;
    background: var(--green);
    color: var(--bg);
    border-radius: 10px;
    font-family: 'SF Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta-btn:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--green-glow);
  }
</style>
