---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketingNav from '../../components/MarketingNav.astro';
import MarketingFooter from '../../components/MarketingFooter.astro';
import { Picture } from 'astro:assets';
import '../../styles/marketing.css';
import { features, getRelated } from '../../data/features.ts';

export function getStaticPaths() {
  return features.map(f => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const { feature } = Astro.props;
const { slug, eyebrow, title, quickAnswer, intro, bullets, images } = feature;
const related = getRelated(slug);

const rawDesc = quickAnswer ?? intro;
const metaDescription = rawDesc.length > 155 ? rawDesc.slice(0, 152) + '...' : rawDesc;
const metaTitle = `${title} for Coworking Spaces — OhMyDesk`;
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={`https://ohmydesk.app/features/${slug}`}
>
  <main>
    <MarketingNav />

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/features/">Features</a>
      <span aria-hidden="true">›</span>
      <span>{eyebrow}</span>
    </nav>

    <section class="hero">
      <span class="eyebrow-chip">{eyebrow}</span>
      <h1>{title}</h1>
      {quickAnswer && <p class="quick-answer">{quickAnswer}</p>}
      <p class="intro">{intro}</p>
    </section>

    {images.length > 0 && (
      <div class="shot-wrap">
        {images.map((img, i) => (
          <figure>
            <Picture
              src={img.src}
              alt={img.alt}
              formats={['avif', 'webp']}
              widths={[480, 720, 1080, 1440]}
              sizes="(max-width: 880px) 100vw, 860px"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </figure>
        ))}
      </div>
    )}

    <section class="bullets-section">
      <h2>What you get</h2>
      <ul class="bullets">
        {bullets.map(b => (
          <li>
            <svg class="check" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8.5l3.5 3.5L13 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="related">
      <h2>Explore more features</h2>
      <div class="related-grid">
        {related.map(f => (
          <a href={`/features/${f.slug}/`} class="related-card">
            <span class="related-eyebrow">{f.eyebrow}</span>
            <h3>{f.title}</h3>
            <p>{f.intro.length > 110 ? f.intro.slice(0, 107) + '…' : f.intro}</p>
            <span class="learn-more">Learn more →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <h2>Try every feature free for 3 months.</h2>
      <p>No credit card. Set up your space in under two minutes.</p>
      <a href="/signup/" class="cta-btn">Start Free Trial</a>
    </section>

    <MarketingFooter />
  </main>
</BaseLayout>

<style is:global>
  main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 32px 0 0;
    font-size: 14px;
    color: var(--text-muted);
  }
  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .breadcrumb a:hover { color: var(--green); }

  /* Hero */
  .hero {
    padding: 40px 0 48px;
    max-width: 760px;
  }
  .eyebrow-chip {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 24px;
    letter-spacing: -0.75px;
  }
  .quick-answer {
    font-size: 16px;
    color: var(--text-primary);
    line-height: 1.6;
    margin: 0 0 20px;
    padding: 14px 18px;
    background: rgba(52, 211, 153, 0.06);
    border-left: 3px solid var(--green);
    border-radius: 0 6px 6px 0;
  }
  .intro {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Screenshot */
  .shot-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 64px;
  }
  .shot-wrap figure {
    margin: 0;
    border-radius: 12px;
    border: 1px solid var(--border-bright);
    overflow: hidden;
    background: var(--bg-card);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(52, 211, 153, 0.05);
  }
  .shot-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Bullets */
  .bullets-section {
    margin-bottom: 72px;
    max-width: 680px;
  }
  .bullets-section h2 {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    margin: 0 0 28px;
    letter-spacing: -0.3px;
  }
  .bullets {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bullets li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 16px;
    color: var(--text-primary);
    line-height: 1.55;
  }
  .check {
    width: 16px;
    height: 16px;
    color: var(--green);
    flex-shrink: 0;
    margin-top: 4px;
  }

  /* Related */
  .related {
    border-top: 1px solid var(--border);
    padding-top: 64px;
    margin-bottom: 72px;
  }
  .related h2 {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    margin: 0 0 32px;
    letter-spacing: -0.3px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 720px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .related-card:hover {
    border-color: rgba(52, 211, 153, 0.35);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(52, 211, 153, 0.1);
  }
  .related-eyebrow {
    font-family: 'SF Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--green);
  }
  .related-card h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }
  .related-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .learn-more {
    font-size: 13px;
    color: var(--green);
    font-weight: 500;
    margin-top: 4px;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: 72px 0 80px;
    border-top: 1px solid var(--border);
  }
  .cta-section h2 {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }
  .cta-section p {
    color: var(--text-secondary);
    font-size: 17px;
    margin: 0 0 32px;
  }
  .cta-btn {
    display: inline-block;
    padding: 16px 36px;
    background: var(--green);
    color: var(--bg);
    border-radius: 10px;
    font-family: 'SF Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta-btn:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--green-glow);
  }
</style>
