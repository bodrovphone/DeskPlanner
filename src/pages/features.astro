---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketingNav from '../components/MarketingNav.astro';
import MarketingFooter from '../components/MarketingFooter.astro';
import { Picture } from 'astro:assets';
import '../styles/marketing.css';
import heroCalendar from '../assets/screenshots/hero-calendar.png';
import { features } from '../data/features.ts';
---

<BaseLayout
  title="OhMyDesk Features — Coworking Software Built for Operators"
  description="Visual booking calendar, member management, flex plans, public booking, multi-location, revenue tracking, and more. Every feature OhMyDesk offers, in one place."
  canonical="https://ohmydesk.app/features/"
>
  <MarketingNav />
  <main>

    <!-- Hero -->
    <section class="hero">
      <span class="eyebrow">Features</span>
      <h1>Everything you need to run a<br/><span class="accent">coworking space.</span></h1>
      <p class="lede">
        Visual booking, member management, flex plans, revenue tracking, public booking,
        and more. Built specifically for the people running coworking spaces — not retrofitted
        from a generic calendar app.
      </p>
      <div class="hero-shot">
        <Picture
          src={heroCalendar}
          alt="OhMyDesk calendar showing weekly desk availability across multiple rooms"
          formats={['avif', 'webp']}
          widths={[640, 960, 1280, 1920]}
          sizes="(max-width: 880px) 100vw, 980px"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </section>

    <!-- Sidebar + sections -->
    <div class="layout">
      <aside class="sidebar" aria-label="Features navigation">
        <p class="sidebar-title">On this page</p>
        <ul>
          {features.map((f) => (
            <li><a href={`#${f.slug}`}>{f.eyebrow}</a></li>
          ))}
        </ul>
      </aside>

      <div class="sections">
        {features.map((f, i) => (
          <article id={f.slug} class="feature">
            <span class="feature-eyebrow">{f.eyebrow}</span>
            <h2>{f.title}</h2>
            {'quickAnswer' in f && f.quickAnswer && (
              <p class="feature-quick-answer">{f.quickAnswer}</p>
            )}
            <p class="feature-intro">{f.intro}</p>
            <ul class="feature-bullets">
              {f.bullets.map((b) => (
                <li>
                  <svg class="check" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M3 8.5l3.5 3.5L13 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            {f.images && f.images.length > 0 && (
              <div class={`feature-shots${f.images.length > 1 ? ' feature-shots--two' : ''}`}>
                {f.images.map((img) => (
                  <figure>
                    <Picture
                      src={img.src}
                      alt={img.alt}
                      formats={['avif', 'webp']}
                      widths={[480, 720, 1080, 1440]}
                      sizes={f.images.length > 1
                        ? '(max-width: 720px) 100vw, 340px'
                        : '(max-width: 880px) 100vw, 720px'}
                      loading="lazy"
                    />
                  </figure>
                ))}
              </div>
            )}
            <a href={`/features/${f.slug}/`} class="feature-deeplink">
              Learn more about {f.eyebrow.toLowerCase()} →
            </a>
            {i < features.length - 1 && <hr/>}
          </article>
        ))}
      </div>
    </div>

    <!-- Final CTA -->
    <section class="final-cta">
      <h2>Try every feature free for 3 months.</h2>
      <p>No credit card. Set up your space in under two minutes.</p>
      <a href="/signup/" class="cta--big">Start Free Trial</a>
    </section>

    <MarketingFooter />
  </main>
</BaseLayout>

<style is:global>
  main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .hero {
    padding: 96px 0 56px;
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 24px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 24px;
    letter-spacing: -1px;
  }
  .hero h1 .accent { color: var(--green); }
  .hero .lede {
    max-width: 680px;
    margin: 0 auto;
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .hero-shot {
    margin: 56px auto 0;
    max-width: 980px;
    border-radius: 14px;
    border: 1px solid var(--border-bright);
    overflow: hidden;
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(52, 211, 153, 0.06),
      0 0 60px rgba(52, 211, 153, 0.08);
  }
  .hero-shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Layout: sticky sidebar + content */
  .layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    padding: 56px 0 80px;
    align-items: start;
  }
  @media (max-width: 880px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 40px 0 60px;
    }
  }

  .sidebar {
    position: sticky;
    top: 32px;
    align-self: start;
  }
  @media (max-width: 880px) {
    .sidebar {
      position: static;
      border-bottom: 1px solid var(--border);
      padding-bottom: 24px;
    }
  }
  .sidebar-title {
    font-family: 'SF Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin: 0 0 16px;
  }
  .sidebar ul {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  @media (max-width: 880px) {
    .sidebar ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
    }
  }
  .sidebar a {
    display: block;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
  }
  @media (max-width: 880px) {
    .sidebar a {
      border-left: none;
      border: 1px solid var(--border);
    }
  }
  .sidebar a:hover {
    color: var(--green);
    border-left-color: var(--green);
    background: var(--green-faint);
  }

  /* Feature sections */
  .sections {
    min-width: 0;
  }
  .feature {
    scroll-margin-top: 32px;
  }
  .feature-eyebrow {
    display: inline-block;
    font-family: 'SF Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--green);
    margin-bottom: 12px;
  }
  .feature h2 {
    font-size: clamp(26px, 3.5vw, 34px);
    font-weight: 700;
    margin: 0 0 18px;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .feature-quick-answer {
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.6;
    margin: 0 0 20px;
    padding: 14px 18px;
    background: rgba(52, 211, 153, 0.06);
    border-left: 3px solid var(--green);
    border-radius: 0 6px 6px 0;
  }
  .feature-intro {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0 0 24px;
    max-width: 680px;
  }
  .feature-bullets {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 680px;
  }
  .feature-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.55;
  }
  .check {
    width: 16px;
    height: 16px;
    color: var(--green);
    flex-shrink: 0;
    margin-top: 4px;
  }
  .feature-shots {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .feature-shots--two {
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 720px) {
    .feature-shots--two {
      grid-template-columns: 1fr;
    }
  }
  .feature-shots figure {
    margin: 0;
    border-radius: 12px;
    border: 1px solid var(--border-bright);
    overflow: hidden;
    background: var(--bg-card);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(52, 211, 153, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .feature-shots figure:hover {
    transform: translateY(-2px);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(52, 211, 153, 0.12),
      0 0 32px rgba(52, 211, 153, 0.08);
  }
  .feature-shots img {
    display: block;
    width: 100%;
    height: auto;
  }

  .feature-deeplink {
    display: inline-block;
    margin-top: 20px;
    font-size: 14px;
    font-weight: 500;
    color: var(--green);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .feature-deeplink:hover { opacity: 0.75; }

  .feature hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 56px 0;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }
  .final-cta h2 {
    font-size: clamp(28px, 4.5vw, 42px);
    font-weight: 700;
    margin: 0 0 12px;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .final-cta p {
    color: var(--text-secondary);
    font-size: 17px;
    margin: 0 0 32px;
  }
  .cta--big {
    display: inline-block;
    padding: 16px 36px;
    background: var(--green);
    color: var(--bg);
    border-radius: 10px;
    font-family: 'SF Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta--big:hover {
    background: var(--green-dim);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--green-glow);
  }
</style>
