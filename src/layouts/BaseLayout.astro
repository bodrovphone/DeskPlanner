---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** Set false to omit the default SoftwareApplication JSON-LD (e.g. when the page provides its own schema in the `head` slot) */
  defaultStructuredData?: boolean;
}

const {
  title = 'OhMyDesk - Coworking Desk Booking & Management Software',
  description = 'Coworking desk booking and management software. Visual calendar, revenue tracking, waiting lists, and meeting room scheduling. Free trial, set up in under 2 minutes.',
  canonical = 'https://ohmydesk.app/',
  ogImage = 'https://ohmydesk.app/og-image.png',
  defaultStructuredData = true,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="OhMyDesk" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Organization schema — always present, helps AI systems attribute brand info -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "OhMyDesk",
      "url": "https://ohmydesk.app",
      "logo": "https://ohmydesk.app/favicon.svg",
      "description": "Coworking desk booking and management software for space operators.",
      "email": "hello@ohmydesk.app",
      "sameAs": [
        "https://www.linkedin.com/company/ohmydesk-app"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "hello@ohmydesk.app"
      }
    })} />

    {defaultStructuredData && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "OhMyDesk",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "Coworking desk booking and management software with visual calendar, revenue tracking, waiting lists, and meeting room scheduling.",
        "url": "https://ohmydesk.app",
        "offers": [
          {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "description": "Free trial - 3 months",
            "availability": "https://schema.org/OnlineOnly"
          },
          {
            "@type": "Offer",
            "price": "18",
            "priceCurrency": "USD",
            "description": "Pro plan - monthly",
            "availability": "https://schema.org/OnlineOnly"
          }
        ],
        "creator": {
          "@type": "Organization",
          "name": "OhMyDesk",
          "url": "https://ohmydesk.app",
          "email": "hello@ohmydesk.app"
        }
      })} />
    )}

    <!-- Page-specific head content (additional structured data, custom meta) -->
    <slot name="head" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script defer src="https://ohmydesk-analytics.bodrovphone.workers.dev/s.js" data-website-id="1f5154a8-b100-4034-8bf9-ed3bf8399f9a"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
