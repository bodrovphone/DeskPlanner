# Prevent browsers from serving stale HTML for SPA routes.
# Hashed assets (/astro-assets/*) are immutable and cache-safe.
#
# Strict-Transport-Security: tells browsers (and Googlebot, after the first
# successful HTTPS hit) to skip HTTP entirely. Closes the http://ohmydesk.app
# duplicate-URL leak that was splitting authority in GSC.

/*
  Cache-Control: no-cache
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/astro-assets/*
  Cache-Control: public, max-age=31536000, immutable
